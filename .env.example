# Email Configuration for Student Invitations
# Add these to your .env file to enable email sending

# SendGrid SMTP Configuration (Recommended for production)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@rozna.com

# Alternative SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# For Gmail, you'll need to:
# 1. Enable 2-factor authentication
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password above (not your regular password)

# Alternative SMTP providers:
# Outlook: smtp.office365.com:587
# Yahoo: smtp.mail.yahoo.com:587
# SendGrid: smtp.sendgrid.net:587

# AI Provider Configuration
# Choose between: openai or openrouter
AI_PROVIDER=openrouter

# OpenAI (used for AI worksheet and flashcard generation when AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (used for AI worksheet and flashcard generation when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLAMA_MODEL=meta-llama/llama-3-8b-instruct
OPENROUTER_TIMEOUT_MS=60000

# AI Retry Configuration (applies to both OpenAI and OpenRouter)
AI_MAX_RETRIES=3
AI_RETRY_DELAY_MS=1000

# Unsplash (used for flashcard image generation)
UNSPLASH_ACCESS_KEY=T6vvL4fu1UwoWJW_Bf20F7HS1lXYoyYy-TybC_ZT41g
UNSPLASH_SECRET_KEY=zIm0TONeMKPK0lcslLpsWDWCprbf4xAA5Mh6EcGGouY

# Frontend URL (used for verification and reset links)
FRONTEND_URL=http://localhost:4200
