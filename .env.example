# Email Configuration for Student Invitations
# Add these to your .env file to enable email sending

# SendGrid SMTP Configuration (Recommended for production)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@rozna.com

# Alternative SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# For Gmail, you'll need to:
# 1. Enable 2-factor authentication
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password above (not your regular password)

# Alternative SMTP providers:
# Outlook: smtp.office365.com:587
# Yahoo: smtp.mail.yahoo.com:587
# SendGrid: smtp.sendgrid.net:587

# AI Provider Configuration
# Primary provider for rubric and AI generation
PRIMARY_AI_PROVIDER=openrouter
PRIMARY_AI_MODEL=openai/gpt-oss-120b
# Optional fixed model for latency-sensitive practice generation. This does not change grading models.
ADAPTIVE_PRACTICE_MODEL=
RUBRIC_AI_MODEL=openai/gpt-oss-120b

# OpenAI (used for AI worksheet and flashcard generation when AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (used for AI worksheet and flashcard generation when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=60000

# AI Retry Configuration (applies to both OpenAI and OpenRouter)
AI_MAX_RETRIES=3
AI_RETRY_DELAY_MS=1000

# Semantic writing analysis (Content / Organization / Vocabulary only)
# Canonical semantic scoring and detailed feedback only. Google uses GEMINI_API_KEY
# directly; these settings do not affect PRIMARY_AI_MODEL, RUBRIC_AI_MODEL,
# adaptive practice, OCR, or PUBLIC_API_URL. Fallback is used only under the
# bounded existing retry policy and only when its model is explicitly approved.
GEMINI_API_KEY=your_gemini_api_key_here
SEMANTIC_AI_PROVIDER=google
SEMANTIC_AI_MODEL=gemini-2.5-flash
SEMANTIC_AI_ATTEMPT_TIMEOUT_MS=45000
SEMANTIC_AI_TOTAL_BUDGET_MS=90000
SEMANTIC_AI_MAX_RETRIES=1
SEMANTIC_AI_RETRY_DELAY_MS=2000
SEMANTIC_AI_MIN_ATTEMPT_BUDGET_MS=10000
SEMANTIC_AI_MAX_OUTPUT_TOKENS=2400
SEMANTIC_AI_FALLBACK_PROVIDER=openrouter
SEMANTIC_AI_FALLBACK_MODEL=openai/gpt-oss-20b
SEMANTIC_AI_APPROVED_MODELS=gemini-2.5-flash,openai/gpt-oss-20b

# Unsplash (used for flashcard image generation)
UNSPLASH_ACCESS_KEY=T6vvL4fu1UwoWJW_Bf20F7HS1lXYoyYy-TybC_ZT41g
UNSPLASH_SECRET_KEY=zIm0TONeMKPK0lcslLpsWDWCprbf4xAA5Mh6EcGGouY

# Frontend URL (used for verification and reset links)
BASE_URL=https://comarkerback.roznahub.com
FRONTEND_URL=https://comarkers.roznahub.com
CORS_ORIGINS=https://comarkers.roznahub.com

# Canonical externally reachable backend origin used in newly persisted upload URLs.
PUBLIC_API_URL=https://comarkerback.roznahub.com
